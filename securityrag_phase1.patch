+"""Central configuration for SecurityRAG.
+
+Loads environment variables and exposes project-wide settings such as
+paths, model names, and vector store options. Other modules should import
+configuration values from here instead of reading environment variables
+directly.
+"""
+
+import os
+from pathlib import Path
+
+from dotenv import load_dotenv
+
+load_dotenv()
+
+# Project paths
+BASE_DIR = Path(__file__).resolve().parent.parent
+DATA_DIR = BASE_DIR / "data"
+DOCS_DIR = BASE_DIR / "docs"
+CHROMA_PERSIST_DIR = BASE_DIR / "chroma_db"
+
+# OpenAI / LLM settings
+OPENAI_API_KEY = os.getenv("OPENAI_API_KEY", "")
+LLM_MODEL_NAME = os.getenv("LLM_MODEL_NAME", "gpt-4o-mini")
+LLM_TEMPERATURE = float(os.getenv("LLM_TEMPERATURE", "0.1"))
+
+# Embedding model settings
+EMBEDDING_MODEL_NAME = os.getenv(
+    "EMBEDDING_MODEL_NAME", "sentence-transformers/all-MiniLM-L6-v2"
+)
+
+# Vector store settings
+CHROMA_COLLECTION_NAME = os.getenv("CHROMA_COLLECTION_NAME", "security_knowledge")
+
+# Retrieval settings
+RETRIEVER_TOP_K = int(os.getenv("RETRIEVER_TOP_K", "4"))
+
+# Prompt template path
+SECURITY_PROMPT_PATH = BASE_DIR / "app" / "prompts" / "security_prompt.txt"
