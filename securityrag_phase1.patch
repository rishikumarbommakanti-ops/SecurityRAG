+"""Streamlit entry point for SecurityRAG.
+
+This is a skeleton UI for the AI-powered Security Knowledge Assistant. It
+currently provides a chat-style interface for entering questions, but the
+underlying RAG pipeline (retrieval + LLM answer generation) is not yet wired
+up — that will be implemented in a later phase.
+"""
+
+import streamlit as st
+
+from app import config
+
+st.set_page_config(
+    page_title="SecurityRAG - Security Knowledge Assistant",
+    page_icon="🛡️",
+    layout="wide",
+)
+
+
+def render_sidebar() -> None:
+    """Render the sidebar with project information and settings."""
+    with st.sidebar:
+        st.header("SecurityRAG")
+        st.caption("AI-powered Security Knowledge Assistant")
+        st.markdown(
+            "**Sources:**\n"
+            "- MITRE ATT&CK\n"
+            "- Sigma Rules\n"
+            "- Security Documentation\n"
+            "- DFIR Playbooks"
+        )
+        st.divider()
+        st.text(f"LLM model: {config.LLM_MODEL_NAME}")
+        st.text(f"Embedding model: {config.EMBEDDING_MODEL_NAME}")
+        st.text(f"Top-K retrieval: {config.RETRIEVER_TOP_K}")
+
+
+def render_chat() -> None:
+    """Render the main chat interface for asking security questions."""
+    st.title("🛡️ SecurityRAG")
+    st.write(
+        "Ask natural language security questions and get contextual answers "
+        "with source citations from trusted cybersecurity knowledge sources."
+    )
+
+    if "messages" not in st.session_state:
+        st.session_state.messages = []
+
+    for message in st.session_state.messages:
+        with st.chat_message(message["role"]):
+            st.markdown(message["content"])
+
+    user_query = st.chat_input("Ask a security question (e.g. 'Explain T1059')")
+    if user_query:
+        st.session_state.messages.append({"role": "user", "content": user_query})
+        with st.chat_message("user"):
+            st.markdown(user_query)
+
+        with st.chat_message("assistant"):
+            placeholder_response = (
+                "The retrieval and answer-generation pipeline is not yet implemented. "
+                "This is currently a Phase 1 skeleton."
+            )
+            st.markdown(placeholder_response)
+        st.session_state.messages.append(
+            {"role": "assistant", "content": placeholder_response}
+        )
+
+
+def main() -> None:
+    """Application entry point."""
+    render_sidebar()
+    render_chat()
+
+
+if __name__ == "__main__":
+    main()
